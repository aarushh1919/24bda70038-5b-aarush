<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><%= title %></h1>
            <a href="/new" class="btn btn-primary">New Student</a>
        </div>

        <% if (message) { %>
            <div class="alert alert-success">
                <%= message %>
            </div>
        <% } %>

        <% if (students.length > 0) { %>
            <div class="students-list">
                <% students.forEach(function(student) { %>
                    <div class="student-card">
                        <h2><%= student.name %></h2>
                        <p><strong>Roll:</strong> <%= student.roll %></p>
                        <p><strong>Email:</strong> <%= student.email %></p>
                        <p><strong>Phone:</strong> <%= student.phone %></p>
                        <p><strong>Address:</strong> <%= student.address %></p>
                        
                        <div class="actions">
                            <a href="/edit/<%= student._id %>" class="btn btn-edit">Edit</a>
                            <form method="POST" action="/delete/<%= student._id %>" style="display: inline;">
                                <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this student?');">Delete</button>
                            </form>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="no-students">
                <p>No students found. <a href="/new">Add a new student</a></p>
            </div>
        <% } %>
    </div>
</body>
</html>
